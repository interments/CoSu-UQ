# Common runtime configuration for CoSu-UQ pipeline scripts.
# You can override any variable before running scripts.

PYTHON_BIN="python"

# Project paths
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
SRC_DIR="${REPO_ROOT}/src"
RESULTS_DIR="${REPO_ROOT}/results"
DATASETS_DIR="${REPO_ROOT}/datasets"

# Stage 0 dataset build
DATASETS="gsm8k hotpotqa math 2wiki medqa"
NUM_SAMPLES=500
WIKI2_HF_REPO="scholarly-shadows-syndicate/2wikimultihopqa_with_qid"
WIKI2_HF_SPLIT="train"

# Stage 1 generation
MODEL_NAME="Llama-3.1-8B"
MODEL_DIR="/path/to/local/model"
DATA_FILE="${DATASETS_DIR}/gsm8k_cot_uq_validation_0-500_src.jsonl"
FRACTION=0.6
MAX_LENGTH=512
NUM_GENERATIONS=5
TEMPERATURE=1.0
TOP_K=5
TOP_P=0.95
DECODE_METHOD="greedy"
SEED=42
DEVICE="0"
USE_API="false"
API_KEY=""
API_BASE=""
API_MODEL_NAME=""

# Stage 2/3/4 models
NLI_MODEL="potsawee/deberta-v3-large-mnli"
SPLIT_METHOD="step_answer"
SAVE_MATRIX="false"

# Stage 4 confidence extraction
TOKENIZER_MODEL_DIR="${MODEL_DIR}"

# Stage 5 judge + AUROC labels
MAX_RETRIES=3
RETRY_INTERVAL=5.0
# Space separated list; each item format:
# model[split]api_base[split]api_key[split]temperature[split]top_p
JUDGERS=""
OVERWRITE_AUROC_LABELS="false"

# Baseline cache settings
SENT_SIM_MODEL="cross-encoder/stsb-roberta-large"
TOKEN_IMPT_MODEL="cross-encoder/stsb-roberta-large"
NUM_GENERATION_FOR_BASELINE=5
SAR_TEMPERATURE=0.001

# CoT-UQ baseline (stage 6c)
COTUQ_PROMPT_TYPE="src"
COTUQ_AGG_METHOD="probas_min"   # choices: probas_mean, probas_min, token_sar
COTUQ_USE_GREEDY="false"       # false = sampled (recommended, aligns with paper baseline)

# Final compare
RUN_SETTINGS_JSON=""
MAX_WORKERS=8
OUTPUT_CSV="${RESULTS_DIR}/final_uq_baseline_compare.csv"

# Optional: explicitly set RUN_SETTING. If empty, scripts derive from stage-1 args.
RUN_SETTING=""
